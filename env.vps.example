# Copy to env.vps next to this file (the engine repo root - the same dir
# kickoff.sh lives in) on the VPS and edit if needed.
# This file is intentionally ignored by git.
#
# Per-user VPS config for the laddy engine (spec 2026-07-13, GitHub-free).
# ONE topology: this user owns one target (~/repo_<project>) and one engine
# (~/laddy). No GitHub credential of any kind exists on this box - the only
# permitted secrets are the agent CLI auth + NTFY_TOPIC (spec 7 allowlist).
# The hub is a LOCAL bare repo; everything reaches it by the Director's push.
#
# VPS node: runs the developer + two-reviewer loop, one worktree per task under
# $AGENT_WORK_ROOT/wt/<task> on its own bare <task> branch. Only the keys the
# Python orchestrator (engine repo's orchestrator/, kickoff.sh) actually reads
# are here.
# Sourced with `set -a` (kickoff.sh) - no spaces around `=`, quote any value
# that contains spaces.

DEFAULT_BRANCH=main
MAX_LOOPS=4

# REQUIRED - the target hub: a LOCAL bare repo path ($HOME, not ~ - this file
# is sourced by a shell, not glob-expanded, so $HOME works but ~ would not).
# No default: a silent GitHub fallback is exactly what this topology forbids.
AGENT_REPO_URL=$HOME/repo_myapp/hub.git

# Workspace root: base clone at $AGENT_WORK_ROOT/base, per-task worktrees under
# $AGENT_WORK_ROOT/wt/<task>. Created lazily on the first kickoff.
AGENT_WORK_ROOT=$HOME/repo_myapp

# Log dir for the detached loop output (kickoff.sh writes <task>.log here;
# watch-vps.sh tails the same path).
AGENT_LOG_DIR=$HOME/agent-logs

# Engine artifact dir name inside the target repo (holds specs/plans/reports).
# Only override if you're running a second engine against the same target.
#LADDY_TARGET_DIR=.laddy

# Headless agent backends. The orchestrator REQUIRES structured JSON from Claude
# (session ids + is_error detection) and appends `--output-format json`
# automatically if you omit it here.
CLAUDE_CMD="claude -p --dangerously-skip-permissions"
CODEX_CMD="codex exec --full-auto"

# Fast inner test gate command (runs in the task worktree; the authoritative
# full gate runs later during LOCAL verify, not here).
# TEST_COMMANDS=". .venv/bin/activate && ruff check . && basedpyright && pytest -n auto -q"

# ntfy topic for terminal-state pushes (unlisted; no secret). Empty = off.
# NTFY_TOPIC=

# Senior escalation model override (defaults to claude + --model claude-opus-4-8).
# SENIOR_CMD="claude -p --dangerously-skip-permissions --output-format json --model claude-opus-4-8"

# --- Quota-window handling (spec: quota-resume-queue) -----------------------
# Extra seconds to wait past a parsed window-reset time.
#QUOTA_RESET_BUFFER_SECONDS=120
# Backoff schedule (minutes, comma-separated) when the CLI reports no reset
# time; the last value repeats.
#QUOTA_BACKOFF_MINUTES=15,30,60
# Cumulative wait cap per task run; exceeding it ends the run as
# QUOTA_TIMEOUT (30h covers a weekend/weekly reset).
#QUOTA_MAX_WAIT_HOURS=30
