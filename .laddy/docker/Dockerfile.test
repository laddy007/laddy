FROM python:3.11-slim

# Base tooling: git for the checkout, curl+ca-certificates to fetch the pinned
# gitleaks release binary below, tar to unpack it.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates tar \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

# Engine dev deps (lint / types / fast tests): pytest, pytest-xdist, ruff,
# basedpyright.
COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt

# Binding-gate scanners (orchestrator/testgate.py _binding_gate). Pinned so the
# gate is reproducible: pytest-cov drives `--cov`, diff-cover scores
# changed-line coverage, semgrep is the SAST step. Bump deliberately.
RUN pip install --no-cache-dir \
      pytest-cov==7.1.0 \
      diff-cover==10.3.0 \
      semgrep==1.169.0

# gitleaks is a Go binary (not on PyPI). Pin the release and verify its sha256
# so the gate image stays reproducible and tamper-evident. linux_x64 matches
# the VPS / local trusted-machine gate arch.
ARG GITLEAKS_VERSION=8.30.1
ARG GITLEAKS_SHA256=551f6fc83ea457d62a0d98237cbad105af8d557003051f41f3e7ca7b3f2470eb
RUN curl -fsSL -o /tmp/gitleaks.tar.gz \
      "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" \
    && echo "${GITLEAKS_SHA256}  /tmp/gitleaks.tar.gz" | sha256sum -c - \
    && tar -xzf /tmp/gitleaks.tar.gz -C /usr/local/bin gitleaks \
    && rm /tmp/gitleaks.tar.gz \
    && gitleaks version

COPY . .
