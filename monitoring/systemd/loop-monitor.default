# loop-monitor defaults. Values are intentionally conservative for a
# 6-vCPU / 11-GiB development VPS.
LOOP_MONITOR_DATA_DIR=/var/lib/loop-monitor
LOOP_MONITOR_SOCKET=/run/loop-monitor/events.sock
LOOP_MONITOR_INTERVAL=15
LOOP_MONITOR_RETENTION_DAYS=21
LOOP_MONITOR_CPU_INCIDENT_PCT=70
LOOP_MONITOR_MEMORY_AVAILABLE_INCIDENT_PCT=15
LOOP_MONITOR_LOAD_INCIDENT_PER_CPU=1
LOOP_MONITOR_IO_FULL_PRESSURE_INCIDENT_PCT=1
LOOP_MONITOR_INCIDENT_DETAIL_INTERVAL=30
LOOP_MONITOR_DOCKER_INSPECT_REFRESH=300
LOOP_MONITOR_TOP_PROCESS_LIMIT=20
