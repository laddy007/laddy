# Copy to env.local next to this file (the engine repo root - the same dir
# merge-verified.sh lives in) and edit if needed.
# This file is intentionally ignored by git.
#
# LOCAL node: the ONLY node with GitHub access (spec 3). origin = GitHub.
# The 'laddy' remote = the target's hub on the VPS:
#   git remote add laddy ssh://<user-ssh-alias>/home/<user>/repo_<project>/hub.git
# Task branches then appear locally as laddy/<task> (remote-tracking
# namespace) - the flow never checks out or switches your own branch.
# scripts/merge-verified.sh (orchestrator.local_merge) fetches each ready
# <task> branch from the hub, re-derives every gate on trusted infra in a
# sibling worktree, and either no-ff-merges the verified commit into local
# main or holds it for a risk decision. A merge is never automatic to
# GitHub: pushing local main to origin (and deleting the merged branch from
# the hub) is a separate, explicit y/N prompt after the merge.

DEFAULT_BRANCH=main

# Python for the launchers (kickoff/merge-verified). The engine needs 3.11+
# (tomllib); on a machine whose default python3 is older, point this at a
# newer interpreter.
PYTHON_BIN=python3.11

# Linux/WSL workspace for the flow's worktrees + clones. Keep on the Linux
# filesystem, not /mnt/c (fast checkout / test I/O; keeps your repo dir clean).
AGENT_WORK_ROOT="$HOME/agent-work"

# Name of the git remote pointing at the hub (push-hub.sh / merge-verified.sh).
VPS_REMOTE_NAME=laddy

# REQUIRED - consumed by orchestrator.local_merge / OrchestratorConfig on THIS
# node (validation only - local CLIs (orchestrator.local_merge via
# merge-verified.sh, oracle eval-run) operate on the CWD repo via --repo, they
# never clone this URL). For the LOCAL node this is the hub as local sees it:
# the same VPS bare hub named by the `laddy` remote above, over SSH.
AGENT_REPO_URL=ssh://vps-<project>/home/<user>/repo_<project>/hub.git

# Consumed by orchestrator.local_merge (merge-verified.sh) to know where
# the bare <task> branches actually live. Matches VPS_REMOTE_NAME above.
AGENT_BRANCH_REMOTE=laddy

# For watch-vps.sh: the ssh host/alias of the VPS.
VPS_SSH="myapp-vps"

# Engine requires Python 3.11+ (orchestrator/target_policy.py imports the
# stdlib `tomllib`, only present since 3.11). If this host's default `python3`
# is older, point PYTHON_BIN at a 3.11+ interpreter - merge-verified.sh reads
# it, falling back to plain `python3` when unset.
#PYTHON_BIN=python3.11

# Dependency install run before local verification (fresh worktree has no deps).
# Uses a per-worktree venv -- PEP 668 forbids a system-wide pip install on modern
# Debian/Ubuntu. Needs python3-venv installed (apt install python3-venv).
SETUP_COMMANDS="python3 -m venv .venv && .venv/bin/pip install -q -r requirements.txt -r requirements-dev.txt && pnpm install --frozen-lockfile --prefer-offline"
VPS_SSH="vps-<project>"

# Verification commands for the trusted full-suite gate. They run INSIDE the
# containerized gate (.laddy/docker in the target), which owns dependency
# install and any test services - there is no separate host-side setup step.
TEST_COMMANDS=". .venv/bin/activate && ruff check . && basedpyright && pytest -n auto -q"

# Headless agent backends. Claude MUST run in print + skip-permissions mode,
# otherwise it opens the interactive TUI and the loop never completes.
CLAUDE_CMD="claude -p --dangerously-skip-permissions"
CODEX_CMD="codex exec --full-auto"

# --- Per-role runner binding (spec fullrun-s0) ------------------------------
# WHICH agent serves each loop role, plus its model/reasoning, is config-driven
# (no run.py edit). For any role (developer, rw1, rw2, senior, clarify, ...):
#   ROLE_<NAME>_VENDOR    claude | codex   (default: claude)
#   ROLE_<NAME>_MODEL     vendor model id  (maps to the vendor's --model flag)
#   ROLE_<NAME>_THINKING  reasoning effort (codex: low|medium|high;
#                                           claude -p has none -> documented no-op)
# All optional/additive; an unknown vendor is rejected (fail-closed). Example:
# ROLE_RW2_VENDOR=codex
# ROLE_RW2_MODEL=gpt-5
# ROLE_RW2_THINKING=high

# Optional.
MAX_LOOPS=5
